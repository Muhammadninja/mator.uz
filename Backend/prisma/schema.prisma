// ─────────────────────────────────────────────────────────────────────────────
// Mator schema — foundation aligned to the mobile frontend contract (backend.json)
//
// ID conventions:
//   • AppUser            -> UUID (@db.Uuid)
//   • Buyer/transactional -> app-generated prefixed ULID strings (veh_, ord_,
//     pay_, bk_, ai_, msg_, ntf_, dev_, addr_, otp_, myid_*) — generated in the
//     service layer, never exposed as Int.
//   • Catalog reference   -> stable slug strings (make_chevrolet, cat_engine_belts,
//     trim_…, engine_…, svc_…, brand_gates, seller_avtomir).
//   • Internal marketplace (Seller/Telegram/Product/Stock/Brand/CarModel) keeps
//     Int PKs — supply-side bounded context, NOT exposed in the buyer app.
//
// Line-items (order/cart/booking) use a snapshot pattern: plain id columns +
// denormalized title/price, so historical records are immutable against catalog
// changes (no FK cascade on snapshots).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────
enum SellerStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum Role {
  USER
  SELLER
  ADMIN
}

enum AuthProvider {
  GOOGLE
  APPLE
  PHONE_OTP
  MYID
}

enum MyIdStatus {
  NOT_VERIFIED
  PENDING
  VERIFIED
}

enum OtpChannel {
  SMS
  TELEGRAM
}

enum Gender {
  MALE
  FEMALE
}

enum Language {
  RU
  UZ
  EN
}

enum ProviderType {
  MASTER
  STO
}

enum Specialization {
  ENGINE
  TRANSMISSION
  ELECTRICAL
  BODY
  PAINT
  SUSPENSION
  DIAGNOSTICS
  TIRES
  AC
}

enum VehicleTransmission {
  MANUAL
  AUTOMATIC
  CVT
  AMT
  ROBOT
}

enum Drivetrain {
  FWD
  RWD
  AWD
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
  GAS
}

enum VehicleServiceStage {
  QUEUED
  IN_PROGRESS
  AWAITING_PARTS
  READY
  FLAGGED
}

enum CompatibilityStatus {
  FITS
  MAYBE
  DOES_NOT_FIT
}

enum PartCondition {
  NEW
  USED
  REFURBISHED
}

// ── Parts taxonomy (classified by the Telegram bot from title + description) ──
// Two-level category hierarchy. MAIN categories are the home-page grid; VEHICLE
// categories group parts once a make/model is chosen. Both are stored on every
// product so the buyer catalog can filter/facet without extra processing.
enum PartMainCategory {
  BRAKES
  BATTERIES
  FILTERS
  IGNITION
  ENGINE
  ELECTRICAL_PARTS
  OIL_AND_FLUIDS
  BELTS_AND_HOSES
  WIPERS
  LIGHTING
  SUSPENSION
  EXTERIOR
}

enum PartVehicleCategory {
  BRAKE_SYSTEM
  MAINTENANCE_AND_FLUIDS
  SUSPENSION_AND_STEERING
  ELECTRICAL_AND_LIGHTING
  ENGINE
  TRANSMISSION
  HEATING_AND_COOLING
  TUNING_AND_ACCESSORIES
}

// Market of origin of the part, inferred from the vehicle make and/or explicit
// keywords in the listing (Xitoy/Китай/China, Korea/Корея, …).
enum PartOriginRegion {
  CHINA
  EUROPE
  RUSSIA
  KOREA
  USA
  JAPAN
}

// How a listing's part number was labeled by the seller. We NEVER guess the
// type from the number itself or from the LLM — an unlabeled number stays
// UNKNOWN so both GM-number and OEM-number searches can still find it.
//   GM      → seller labeled it a GM number  (gm_number populated, oem_number null)
//   OEM     → seller labeled it an OEM number (oem_number populated, gm_number null)
//   UNKNOWN → unlabeled (Article / Part No. / bare digits) — neither field is
//             authoritative; the raw value is kept in gm_number for the unique
//             key but is searchable as both GM and OEM.
enum PartNumberType {
  GM
  OEM
  UNKNOWN
}

enum BookingStatus {
  HOLD
  CONFIRMED
  CANCELLED
  COMPLETED
  EXPIRED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  EXPIRED
}

enum DeliveryMethod {
  COURIER
  PICKUP
}

// Who performed an order status change, recorded on each OrderStatusHistory row.
// SYSTEM covers automated transitions (order creation, payment webhooks); the
// remaining values map to the acting AppUser's role at write time.
enum OrderActorType {
  SYSTEM
  CUSTOMER
  OPERATOR
  ADMIN
}

enum PaymentProvider {
  PAYME
  CLICK
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
}

enum DevicePlatform {
  IOS
  ANDROID
}

enum NotificationType {
  ORDER_PAID
  ORDER_STATUS_CHANGED
  PAYMENT_PAID
  AI_REPLY
  MASTER_MESSAGE
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  VEHICLE_STATUS_UPDATED
  MYID_VERIFIED
  MARKETING
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ── Internal marketplace (supply-side, Int PKs, NOT exposed to buyer app) ─────
model Seller {
  id             Int          @id @default(autoincrement())
  tgId           BigInt       @unique @map("tg_id")
  phone          String       @db.VarChar(20)
  storeName      String?      @map("store_name") @db.VarChar(100)
  marketName     String?      @map("market_name") @db.VarChar(100)
  addressComment String?      @map("address_comment")
  locationLat    Float?       @map("location_lat")
  locationLng    Float?       @map("location_lng")
  status         SellerStatus @default(PENDING)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  stocks         Stock[]

  @@index([status])
  @@map("sellers")
}

model Brand {
  id     Int        @id @default(autoincrement())
  name   String     @unique @db.VarChar(100)
  models CarModel[]

  @@map("brands")
}

model CarModel {
  id         Int         @id @default(autoincrement())
  brandId    Int         @map("brand_id")
  name       String      @db.VarChar(100)
  brand      Brand       @relation(fields: [brandId], references: [id], onDelete: Cascade)
  partModels PartModel[]

  @@unique([brandId, name])
  @@map("car_models")
}

model Product {
  id              Int                  @id @default(autoincrement())
  // Raw part number as written by the seller. Kept as the unique idempotency key
  // for the Telegram upsert (a synthetic key is used when the listing has none).
  // The AUTHORITATIVE OEM value lives in `oemNumber`; this column is NOT copied
  // into it. See `partNumberType` for how the seller labeled the number.
  gmNumber        String?              @unique @map("gm_number") @db.VarChar(50)
  // OEM number ONLY when the seller explicitly labeled the number as OEM. Never
  // auto-filled from gmNumber, never inferred from the number or the LLM.
  oemNumber       String?              @map("oem_number") @db.VarChar(50)
  // Whether the seller labeled the number GM, OEM, or left it unlabeled (UNKNOWN).
  partNumberType  PartNumberType       @default(UNKNOWN) @map("part_number_type")
  title           String               @db.VarChar(255)
  description     String?              @db.Text
  imageUrl        String?              @map("image_url") // primary image mirror (back-compat)
  // Fits every vehicle. Fitment is otherwise derived from part_models rows:
  // isUniversal=false + 1 row → SINGLE, N rows → MULTIPLE; when true there are
  // no part_models rows for the product.
  isUniversal     Boolean              @default(false) @map("is_universal")
  // Classified by the Telegram bot from title + description (RU/UZ/EN). Nullable
  // so pre-classification rows stay valid; the classifier always assigns a
  // main/vehicle category (fallback when unsure), and the region/flags when
  // inferable. Projected verbatim into catalog_parts for buyer-side filtering.
  mainCategory    PartMainCategory?    @map("main_category")
  vehicleCategory PartVehicleCategory? @map("vehicle_category")
  partBrand       String?              @map("part_brand") @db.VarChar(120)
  originRegion    PartOriginRegion?    @map("origin_region")
  isOem           Boolean              @default(false) @map("is_oem")
  isGm            Boolean              @default(false) @map("is_gm")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  partModels      PartModel[]
  stocks          Stock[]
  images          ProductImage[]

  @@index([mainCategory])
  @@index([vehicleCategory])
  @@map("products")
}

// Ordered gallery for a product (Telegram media-group uploads). The first image
// (sortOrder 0 / isPrimary) mirrors into Product.imageUrl for legacy readers.
model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_images")
}

model PartModel {
  partId  Int      @map("part_id")
  modelId Int      @map("model_id")
  model   CarModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  part    Product  @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@id([partId, modelId])
  @@index([modelId])
  @@map("part_models")
}

// Verified internal OEM → vehicle compatibility. This is the ONLY source from
// which an OEM number may contribute make/model to a listing. It is populated
// MANUALLY over time (starts empty); the parser NEVER writes rows here and NEVER
// infers compatibility from the number itself or from the LLM. One OEM number
// can fit several vehicles, so oemNumber is intentionally NOT unique — one row
// per (oemNumber, make, model). No match → no compatibility.
model OemCompatibility {
  id        Int      @id @default(autoincrement())
  oemNumber String   @map("oem_number") @db.VarChar(50)
  make      String   @db.VarChar(120)
  model     String   @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([oemNumber, make, model])
  @@index([oemNumber])
  @@map("oem_compatibility")
}

model Stock {
  id        Int      @id @default(autoincrement())
  sellerId  Int      @map("seller_id")
  productId Int      @map("product_id")
  priceUzs  Decimal  @map("price_uzs") @db.Decimal(14, 2)
  quantity  Int      @default(1)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, productId])
  @@index([productId])
  @@map("stocks")
}

// ── Buyer identity (UUID) ─────────────────────────────────────────────────────
model AppUser {
  id                  String     @id @default(uuid()) @db.Uuid
  email               String?    @unique @db.VarChar(255)
  passwordHash        String?    @map("password_hash") @db.VarChar(255)
  emailVerified       Boolean    @default(false) @map("email_verified")
  phoneE164           String?    @unique @map("phone_e164") @db.VarChar(20)
  phoneVerified       Boolean    @default(false) @map("phone_verified")
  displayName         String?    @map("display_name") @db.VarChar(120)
  firstName           String?    @map("first_name") @db.VarChar(100)
  lastName            String?    @map("last_name") @db.VarChar(100)
  avatarUrl           String?    @map("avatar_url")
  thumbnailUrl        String?    @map("thumbnail_url")
  role                Role       @default(USER)
  language            Language   @default(UZ)
  myIdStatus          MyIdStatus @default(NOT_VERIFIED) @map("myid_status")
  transactionLimitUzs Decimal    @default(0) @map("transaction_limit_uzs") @db.Decimal(14, 2)
  // Session version: every access token carries the value it was signed with;
  // bumping it invalidates all outstanding access tokens on the next request.
  tokenVersion        Int        @default(0) @map("token_version")
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  refreshTokens          RefreshToken[]
  identities             AuthIdentity[]
  emailTokens            EmailVerificationToken[]
  vehicles               Vehicle[]
  orders                 Order[]
  bookings               Booking[]
  cart                   Cart?
  devices                Device[]
  notifications          Notification[]
  notificationPreference NotificationPreference?
  aiSessions             AiSession[]
  addresses              Address[]
  myIdSessions           MyIdSession[]
  myIdVerifications      MyIdVerification[]

  @@map("app_users")
}

model AuthIdentity {
  id             Int          @id @default(autoincrement())
  provider       AuthProvider
  providerUserId String       @map("provider_user_id") @db.VarChar(255)
  email          String?      @db.VarChar(255)
  userId         String       @map("user_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)
  user           AppUser      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("auth_identities")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  userId     String    @map("user_id") @db.Uuid
  deviceId   String?   @map("device_id") @db.VarChar(64) // session<->device binding; null for web/email logins
  // Session version this token was minted under. Rotation refuses a row whose
  // version no longer matches the account, so a refresh token created in the
  // race window of a revocation cannot revive the session it belonged to.
  tokenVersion Int     @default(0) @map("token_version")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(3) // soft-rotation marker for reuse detection
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user       AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  device     Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
  @@index([deviceId])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id         Int       @id @default(autoincrement())
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  userId     String    @map("user_id") @db.Uuid
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user       AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

// Phone OTP (pre-auth; not yet linked to a user). request_id = otp_<ulid>.
model PhoneOtpRequest {
  id          String     @id @db.VarChar(64)
  phoneE164   String     @map("phone_e164") @db.VarChar(20)
  codeHash    String     @map("code_hash") @db.VarChar(64)
  channel     OtpChannel @default(SMS)
  purpose     String     @default("login") @db.VarChar(40)
  attempts    Int        @default(0)
  resendCount Int        @default(0) @map("resend_count")
  expiresAt   DateTime   @map("expires_at") @db.Timestamptz(3)
  consumedAt  DateTime?  @map("consumed_at") @db.Timestamptz(3)
  lastSentAt  DateTime   @default(now()) @map("last_sent_at") @db.Timestamptz(3)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([phoneE164, createdAt]) // supports "N per hour per MSISDN" rate-limit counting
  @@index([expiresAt])
  @@map("phone_otp_requests")
}

// MyID OAuth verification session (myid_sess_<ulid>).
model MyIdSession {
  id                  String   @id @db.VarChar(64)
  userId              String   @map("user_id") @db.Uuid
  state               String   @unique @db.VarChar(120)
  codeChallenge       String   @map("code_challenge") @db.VarChar(255)
  codeChallengeMethod String   @default("S256") @map("code_challenge_method") @db.VarChar(10)
  codeVerifier        String?  @map("code_verifier") @db.VarChar(255) // only set for backend-generated PKCE fallback
  scopes              String[]
  redirectUri         String   @map("redirect_uri")
  status              String   @default("pending") @db.VarChar(20)
  expiresAt           DateTime @map("expires_at") @db.Timestamptz(3)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  user                AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("myid_sessions")
}

// Resolved MyID identity payload (myid_ver_<ulid>).
model MyIdVerification {
  id                  String    @id @db.VarChar(64)
  userId              String    @map("user_id") @db.Uuid
  sessionId           String?   @map("session_id") @db.VarChar(64)
  status              String    @db.VarChar(20)
  pinfl               String?   @db.VarChar(14)
  passportSerial      String?   @map("passport_serial") @db.VarChar(2)
  passportNumber      String?   @map("passport_number") @db.VarChar(20)
  firstName           String?   @map("first_name") @db.VarChar(100)
  lastName            String?   @map("last_name") @db.VarChar(100)
  middleName          String?   @map("middle_name") @db.VarChar(100)
  dateOfBirth         DateTime? @map("date_of_birth") @db.Date
  gender              Gender?
  citizenshipIso3     String?   @map("citizenship_iso3") @db.VarChar(3)
  addressRegion       String?   @map("address_region") @db.VarChar(120)
  addressDistrict     String?   @map("address_district") @db.VarChar(120)
  addressStreet       String?   @map("address_street")
  biometricMatchScore Decimal?  @map("biometric_match_score") @db.Decimal(4, 3)
  verifiedAt          DateTime? @map("verified_at") @db.Timestamptz(3)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user                AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pinfl])
  @@map("myid_verifications")
}

model Address {
  id         String   @id @db.VarChar(64)
  userId     String   @map("user_id") @db.Uuid
  label      String?  @db.VarChar(80)
  regionCode String?  @map("region_code") @db.VarChar(10)
  district   String?  @db.VarChar(120)
  street     String?
  fullText   String   @map("full_text")
  lat        Float?
  lng        Float?
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@index([userId])
  @@map("addresses")
}

// ── Vehicle catalog (buyer garage reference, slug IDs) ────────────────────────
model VehicleMake {
  id        String                  @id @db.VarChar(64)
  name      String                  @db.VarChar(120)
  logoUrl   String?                 @map("logo_url")
  sortOrder Int                     @default(0) @map("sort_order")
  models    VehicleModelRef[]
  vehicles  Vehicle[]
  providers ProviderSupportedMake[]

  @@map("vehicle_makes")
}

model VehicleModelRef {
  id        String        @id @db.VarChar(64)
  makeId    String        @map("make_id") @db.VarChar(64)
  name      String        @db.VarChar(120)
  sortOrder Int           @default(0) @map("sort_order")
  make      VehicleMake   @relation(fields: [makeId], references: [id], onDelete: Cascade)
  trims     VehicleTrim[]
  vehicles  Vehicle[]

  @@index([makeId])
  @@map("vehicle_models")
}

model VehicleTrim {
  id              String              @id @db.VarChar(64)
  modelId         String              @map("model_id") @db.VarChar(64)
  name            String              @db.VarChar(120)
  sortOrder       Int                 @default(0) @map("sort_order")
  model           VehicleModelRef     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  vehicles        Vehicle[]
  assets          Vehicle3dAsset[]
  compatibilities PartCompatibility[]

  @@index([modelId])
  @@map("vehicle_trims")
}

model VehicleEngine {
  id              String              @id @db.VarChar(64)
  name            String              @db.VarChar(120)
  displacementCc  Int?                @map("displacement_cc")
  fuelType        FuelType?           @map("fuel_type")
  sortOrder       Int                 @default(0) @map("sort_order")
  vehicles        Vehicle[]
  compatibilities PartCompatibility[]

  @@map("vehicle_engines")
}

model Vehicle3dAsset {
  id              String          @id @db.VarChar(64)
  trimId          String?         @map("trim_id") @db.VarChar(64)
  glbUrl          String          @map("glb_url")
  ktx2TexturesUrl String?         @map("ktx2_textures_url")
  version         Int             @default(1)
  byteSize        Int?            @map("byte_size")
  checksumSha256  String?         @map("checksum_sha256") @db.VarChar(64)
  trim            VehicleTrim?    @relation(fields: [trimId], references: [id], onDelete: SetNull)
  variants        TuningVariant[]
  vehicles        Vehicle[]

  @@index([trimId])
  @@map("vehicle_3d_assets")
}

model TuningVariant {
  id           String         @id @db.VarChar(64)
  assetId      String         @map("asset_id") @db.VarChar(64)
  name         String         @db.VarChar(120)
  thumbnailUrl String?        @map("thumbnail_url")
  asset        Vehicle3dAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("tuning_variants")
}

// ── User vehicles (veh_<ulid>) ────────────────────────────────────────────────
model Vehicle {
  id                     String               @id @db.VarChar(64)
  userId                 String               @map("user_id") @db.Uuid
  isPrimary              Boolean              @default(false) @map("is_primary")
  nickname               String?              @db.VarChar(120)
  makeId                 String               @map("make_id") @db.VarChar(64)
  modelId                String               @map("model_id") @db.VarChar(64)
  year                   Int
  trimId                 String?              @map("trim_id") @db.VarChar(64)
  engineId               String?              @map("engine_id") @db.VarChar(64)
  transmission           VehicleTransmission?
  drivetrain             Drivetrain?
  colorHex               String?              @map("color_hex") @db.VarChar(9)
  vin                    String?              @db.VarChar(50)
  licensePlate           String?              @map("license_plate") @db.VarChar(20)
  registrationRegionCode String?              @map("registration_region_code") @db.VarChar(10)
  mileageKm              Int?                 @map("mileage_km")
  fuelType               FuelType?            @map("fuel_type")
  model3dAssetId         String?              @map("model_3d_asset_id") @db.VarChar(64)
  deletedAt              DateTime?            @map("deleted_at") @db.Timestamptz(3)
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)

  user         AppUser              @relation(fields: [userId], references: [id], onDelete: Cascade)
  make         VehicleMake          @relation(fields: [makeId], references: [id], onDelete: Restrict)
  model        VehicleModelRef      @relation(fields: [modelId], references: [id], onDelete: Restrict)
  trim         VehicleTrim?         @relation(fields: [trimId], references: [id], onDelete: SetNull)
  engine       VehicleEngine?       @relation(fields: [engineId], references: [id], onDelete: SetNull)
  model3dAsset Vehicle3dAsset?      @relation(fields: [model3dAssetId], references: [id], onDelete: SetNull)
  bookings     Booking[]
  aiSessions   AiSession[]
  orders       Order[]
  statusEvents VehicleStatusEvent[]

  @@index([userId])
  @@index([userId, isPrimary])
  @@map("vehicles")
}

model VehicleStatusEvent {
  id           String              @id @db.VarChar(64)
  vehicleId    String              @map("vehicle_id") @db.VarChar(64)
  stage        VehicleServiceStage
  label        String              @db.VarChar(160)
  note         String?
  mechanicName String?             @map("mechanic_name") @db.VarChar(120)
  emittedAt    DateTime            @map("emitted_at") @db.Timestamptz(3)
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  vehicle      Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@map("vehicle_status_events")
}

// ── Service providers (masters + STO; master_/sto_ <ulid>) ────────────────────
model ServiceProvider {
  id               String       @id @db.VarChar(64)
  providerType     ProviderType @map("provider_type")
  displayName      String       @map("display_name") @db.VarChar(160)
  shopName         String?      @map("shop_name") @db.VarChar(160)
  bio              String?
  avatarUrl        String?      @map("avatar_url")
  ratingAvg        Decimal      @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount      Int          @default(0) @map("rating_count")
  geoLat           Float        @map("geo_lat")
  geoLng           Float        @map("geo_lng")
  geohash          String       @db.VarChar(12)
  addressText      String?      @map("address_text")
  priceFloorUzs    Decimal?     @map("price_floor_uzs") @db.Decimal(14, 2)
  priceCeilingUzs  Decimal?     @map("price_ceiling_uzs") @db.Decimal(14, 2)
  badge            String?      @db.VarChar(40)
  contactPhoneE164 String?      @map("contact_phone_e164") @db.VarChar(20)
  contactTelegram  String?      @map("contact_telegram") @db.VarChar(80)
  contactWebsite   String?      @map("contact_website")
  isActive         Boolean      @default(true) @map("is_active")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  specializations ProviderSpecialization[]
  supportedMakes  ProviderSupportedMake[]
  services        ProviderServiceOffering[]
  workingHours    ProviderWorkingHours[]
  certifications  ProviderCertification[]
  portfolio       ProviderPortfolioItem[]
  bookings        Booking[]

  @@index([providerType])
  @@index([geohash])
  @@index([ratingAvg])
  @@map("service_providers")
}

model ProviderSpecialization {
  providerId     String          @map("provider_id") @db.VarChar(64)
  specialization Specialization
  provider       ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@id([providerId, specialization])
  @@map("provider_specializations")
}

model ProviderSupportedMake {
  providerId String          @map("provider_id") @db.VarChar(64)
  makeId     String          @map("make_id") @db.VarChar(64)
  provider   ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  make       VehicleMake     @relation(fields: [makeId], references: [id], onDelete: Cascade)

  @@id([providerId, makeId])
  @@index([makeId])
  @@map("provider_supported_makes")
}

model ProviderServiceOffering {
  id          String          @id @db.VarChar(64)
  providerId  String          @map("provider_id") @db.VarChar(64)
  name        String          @db.VarChar(160)
  durationMin Int?            @map("duration_min")
  priceUzs    Decimal         @map("price_uzs") @db.Decimal(14, 2)
  serviceType String?         @map("service_type") @db.VarChar(60)
  provider    ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_service_offerings")
}

model ProviderWorkingHours {
  id         String          @id @db.VarChar(64)
  providerId String          @map("provider_id") @db.VarChar(64)
  weekday    Int // 0=Sunday … 6=Saturday
  openTime   String?         @map("open_time") @db.VarChar(5)
  closeTime  String?         @map("close_time") @db.VarChar(5)
  provider   ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, weekday])
  @@map("provider_working_hours")
}

model ProviderCertification {
  id         String          @id @db.VarChar(64)
  providerId String          @map("provider_id") @db.VarChar(64)
  name       String          @db.VarChar(200)
  issuedAt   DateTime?       @map("issued_at") @db.Date
  provider   ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_certifications")
}

model ProviderPortfolioItem {
  id         String          @id @db.VarChar(64)
  providerId String          @map("provider_id") @db.VarChar(64)
  imageUrl   String          @map("image_url")
  sortOrder  Int             @default(0) @map("sort_order")
  provider   ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("provider_portfolio_items")
}

model Booking {
  id               String           @id @db.VarChar(64)
  userId           String           @map("user_id") @db.Uuid
  providerId       String           @map("provider_id") @db.VarChar(64)
  vehicleId        String?          @map("vehicle_id") @db.VarChar(64)
  status           BookingStatus    @default(HOLD)
  scheduledAt      DateTime         @map("scheduled_at") @db.Timestamptz(3)
  holdExpiresAt    DateTime?        @map("hold_expires_at") @db.Timestamptz(3)
  totalUzs         Decimal          @map("total_uzs") @db.Decimal(14, 2)
  notes            String?
  contactPhoneE164 String           @map("contact_phone_e164") @db.VarChar(20)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  user             AppUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider         ServiceProvider  @relation(fields: [providerId], references: [id], onDelete: Restrict)
  vehicle          Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  services         BookingService[]

  @@index([userId])
  @@index([providerId])
  @@index([status])
  @@map("bookings")
}

// Snapshot of the booked service (no FK to keep history immutable).
model BookingService {
  id        String  @id @db.VarChar(64)
  bookingId String  @map("booking_id") @db.VarChar(64)
  serviceId String  @map("service_id") @db.VarChar(64)
  name      String  @db.VarChar(160)
  priceUzs  Decimal @map("price_uzs") @db.Decimal(14, 2)
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_services")
}

// ── Parts catalog (buyer-facing) ──────────────────────────────────────────────
model PartCategory {
  id       String         @id @db.VarChar(64)
  name     String         @db.VarChar(160)
  parentId String?        @map("parent_id") @db.VarChar(64)
  iconUrl  String?        @map("icon_url")
  parent   PartCategory?  @relation("PartCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children PartCategory[] @relation("PartCategoryTree")
  parts    CatalogPart[]

  @@index([parentId])
  @@map("part_categories")
}

model PartBrand {
  id      String        @id @db.VarChar(64)
  name    String        @db.VarChar(120)
  logoUrl String?       @map("logo_url")
  parts   CatalogPart[]

  @@map("part_brands")
}

// Buyer-facing seller projection of the internal Seller (seller_<slug>).
model CatalogSeller {
  id               String        @id @db.VarChar(64)
  name             String        @db.VarChar(160)
  ratingAvg        Decimal       @default(0) @map("rating_avg") @db.Decimal(3, 2)
  logoUrl          String?       @map("logo_url")
  internalSellerId Int?          @map("internal_seller_id") // link to supply-side Seller, not exposed
  // "MATOR Certified" storefront presentation (nullable — only curated dealer
  // rows carry these; projected seller_<id> rows leave them null).
  // `isCurated` is the AUTHORITATIVE marker of a curated dealer — GET /v1/dealers
  // filters on it, NOT on whether these presentation fields happen to be set. A
  // projected seller_<id> row that later acquires an `initial` must never leak
  // into the dealer list, so identity is an explicit flag, not field presence.
  isCurated        Boolean       @default(false) @map("is_curated")
  initial          String?       @db.VarChar(4) // monogram letter for the logo tile
  color            String?       @db.VarChar(9) // brand accent hex (#RRGGBB[AA])
  orders           String?       @db.VarChar(20) // pre-formatted lifetime order count, e.g. "18k+"
  years            Int?          // years in business
  parts            CatalogPart[]

  @@index([internalSellerId])
  @@map("catalog_sellers")
}

model CatalogPart {
  id                 String               @id @db.VarChar(64)
  title              String               @db.VarChar(255)
  brandId            String?              @map("brand_id") @db.VarChar(64)
  categoryId         String               @map("category_id") @db.VarChar(64)
  sellerId           String               @map("seller_id") @db.VarChar(64)
  // OEM numbers this part is sold under. Populated ONLY from a seller-labeled OEM
  // number or an UNKNOWN (unlabeled) number — never from a GM-labeled number.
  oemNumbers         String[]             @map("oem_numbers")
  // GM numbers this part is sold under. Populated ONLY from a seller-labeled GM
  // number or an UNKNOWN (unlabeled) number. An UNKNOWN number appears in BOTH
  // arrays so it is findable by either search; a labeled number appears in one.
  gmNumbers          String[]             @map("gm_numbers")
  // How the seller labeled the number (mirrors Product.partNumberType).
  partNumberType     PartNumberType       @default(UNKNOWN) @map("part_number_type")
  priceUzs           Decimal              @map("price_uzs") @db.Decimal(14, 2)
  currency           String               @default("UZS") @db.VarChar(3)
  condition          PartCondition        @default(NEW)
  inStock            Boolean              @default(true) @map("in_stock")
  deliveryEtaDaysMin Int?                 @map("delivery_eta_days_min")
  deliveryEtaDaysMax Int?                 @map("delivery_eta_days_max")
  images             String[]
  // Classified taxonomy + attributes, projected from the supply-side Product.
  // Indexed for efficient buyer-side filtering/faceting.
  mainCategory       PartMainCategory?    @map("main_category")
  vehicleCategory    PartVehicleCategory? @map("vehicle_category")
  partBrandName      String?              @map("part_brand_name") @db.VarChar(120)
  originRegion       PartOriginRegion?    @map("origin_region")
  isOem              Boolean              @default(false) @map("is_oem")
  isGm               Boolean              @default(false) @map("is_gm")
  isUniversal        Boolean              @default(false) @map("is_universal")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  brand              PartBrand?           @relation(fields: [brandId], references: [id], onDelete: SetNull)
  category           PartCategory         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  seller             CatalogSeller        @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  compatibilities    PartCompatibility[]
  fits               CatalogPartFit[]

  @@index([categoryId])
  @@index([brandId])
  @@index([sellerId])
  @@index([inStock])
  @@index([mainCategory])
  @@index([vehicleCategory])
  @@index([originRegion])
  @@index([isGm])
  @@index([isOem])
  @@map("catalog_parts")
}

// Denormalized make/model fitment for the buyer catalog, projected from the
// supply-side PartModel links. Enables indexed server-side filtering by vehicle
// make and model (independent of the trim/engine-level PartCompatibility used
// for garage-vehicle fit). Names are canonical (see vehicle-catalog.ts); slugs
// mirror the frontend contract's make/model ids (e.g. make_chevrolet).
model CatalogPartFit {
  partId    String      @map("part_id") @db.VarChar(64)
  makeSlug  String      @map("make_slug") @db.VarChar(80)
  modelSlug String      @map("model_slug") @db.VarChar(96)
  makeName  String      @map("make_name") @db.VarChar(120)
  modelName String      @map("model_name") @db.VarChar(120)
  part      CatalogPart @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@id([partId, modelSlug])
  @@index([makeSlug])
  @@index([modelSlug])
  @@map("catalog_part_fits")
}

model PartCompatibility {
  id         String              @id @db.VarChar(64)
  partId     String              @map("part_id") @db.VarChar(64)
  trimId     String?             @map("trim_id") @db.VarChar(64)
  engineId   String?             @map("engine_id") @db.VarChar(64)
  years      Int[]
  status     CompatibilityStatus @default(FITS)
  confidence Decimal             @default(1) @db.Decimal(4, 3)
  source     String?             @db.VarChar(80)
  part       CatalogPart         @relation(fields: [partId], references: [id], onDelete: Cascade)
  trim       VehicleTrim?        @relation(fields: [trimId], references: [id], onDelete: SetNull)
  engine     VehicleEngine?      @relation(fields: [engineId], references: [id], onDelete: SetNull)

  @@index([partId])
  @@index([trimId])
  @@index([engineId])
  @@map("part_compatibilities")
}

// ── Cart (server-persisted, one per user) ─────────────────────────────────────
model Cart {
  id               String     @id @db.VarChar(64)
  userId           String     @unique @map("user_id") @db.Uuid
  promoCode        String?    @map("promo_code") @db.VarChar(60)
  promoDiscountUzs Decimal?   @map("promo_discount_uzs") @db.Decimal(14, 2)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  user             AppUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  items            CartItem[]

  @@map("carts")
}

model CartItem {
  id               String    @id @db.VarChar(64)
  cartId           String    @map("cart_id") @db.VarChar(64)
  partId           String?   @map("part_id") @db.VarChar(64)
  serviceId        String?   @map("service_id") @db.VarChar(64)
  providerId       String?   @map("provider_id") @db.VarChar(64)
  vehicleId        String?   @map("vehicle_id") @db.VarChar(64)
  title            String    @db.VarChar(255)
  imageUrl         String?   @map("image_url")
  quantity         Int       @default(1)
  scheduledAt      DateTime? @map("scheduled_at") @db.Timestamptz(3)
  priceUzsSnapshot Decimal   @map("price_uzs_snapshot") @db.Decimal(14, 2)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  cart             Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@index([cartId])
  @@map("cart_items")
}

// ── Orders & payments ─────────────────────────────────────────────────────────
model Order {
  id                String          @id @db.VarChar(64)
  userId            String          @map("user_id") @db.Uuid
  status            OrderStatus     @default(PENDING_PAYMENT)
  subtotalUzs       Decimal         @map("subtotal_uzs") @db.Decimal(14, 2)
  deliveryUzs       Decimal         @default(0) @map("delivery_uzs") @db.Decimal(14, 2)
  serviceFeeUzs     Decimal         @default(0) @map("service_fee_uzs") @db.Decimal(14, 2)
  discountUzs       Decimal         @default(0) @map("discount_uzs") @db.Decimal(14, 2)
  totalUzs          Decimal         @map("total_uzs") @db.Decimal(14, 2)
  currency          String          @default("UZS") @db.VarChar(3)
  vehicleId         String?         @map("vehicle_id") @db.VarChar(64)
  deliveryAddressId String?         @map("delivery_address_id") @db.VarChar(64)
  deliveryMethod    DeliveryMethod? @map("delivery_method")
  contactPhoneE164  String?         @map("contact_phone_e164") @db.VarChar(20)
  promoCode         String?         @map("promo_code") @db.VarChar(60)
  yandexClaimId     String?         @map("yandex_claim_id") @db.VarChar(100)
  expiresAt         DateTime?       @map("expires_at") @db.Timestamptz(3)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  user              AppUser         @relation(fields: [userId], references: [id], onDelete: Restrict)
  vehicle           Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  deliveryAddress   Address?        @relation(fields: [deliveryAddressId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  payments          Payment[]
  statusHistory     OrderStatusHistory[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

// Snapshot line item (no FK to catalog — immutable order history).
model OrderItem {
  id           String    @id @db.VarChar(64)
  orderId      String    @map("order_id") @db.VarChar(64)
  partId       String?   @map("part_id") @db.VarChar(64)
  serviceId    String?   @map("service_id") @db.VarChar(64)
  providerId   String?   @map("provider_id") @db.VarChar(64)
  title        String    @db.VarChar(255)
  quantity     Int       @default(1)
  priceUzs     Decimal   @map("price_uzs") @db.Decimal(14, 2)
  lineTotalUzs Decimal   @map("line_total_uzs") @db.Decimal(14, 2)
  scheduledAt  DateTime? @map("scheduled_at") @db.Timestamptz(3)
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

// Append-only audit trail of order status transitions. Each row snapshots the
// actor (id + display name at write time, like the SMS accounting snapshot) so
// history stays immutable against later profile edits / user deletion. No FK to
// app_users for the actor — the snapshot is the record of truth. actorType/
// actorId/actorName are null for SYSTEM transitions.
model OrderStatusHistory {
  id        String         @id @db.VarChar(64)
  orderId   String         @map("order_id") @db.VarChar(64)
  status    OrderStatus
  note      String?        @db.VarChar(500)
  actorType OrderActorType @default(SYSTEM) @map("actor_type")
  actorId   String?        @map("actor_id") @db.Uuid
  actorName String?        @map("actor_name") @db.VarChar(120)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model Payment {
  id                    String          @id @db.VarChar(64)
  orderId               String          @map("order_id") @db.VarChar(64)
  provider              PaymentProvider
  status                PaymentStatus   @default(PENDING)
  amountUzs             Decimal         @map("amount_uzs") @db.Decimal(14, 2)
  amountTiyin           BigInt?         @map("amount_tiyin")
  deepLink              String?         @map("deep_link")
  httpsFallback         String?         @map("https_fallback")
  providerTransactionId String?         @map("provider_transaction_id") @db.VarChar(120)
  // Provider transaction state machine (Payme states 1/2/-1/-2; Click prepare id).
  providerState         Int?            @map("provider_state")
  providerCreateTime    BigInt?         @map("provider_create_time")
  providerPerformTime   BigInt?         @map("provider_perform_time")
  providerCancelTime    BigInt?         @map("provider_cancel_time")
  cancelReason          Int?            @map("cancel_reason")
  providerPrepareId     String?         @map("provider_prepare_id") @db.VarChar(64)
  paidAt                DateTime?       @map("paid_at") @db.Timestamptz(3)
  expiresAt             DateTime?       @map("expires_at") @db.Timestamptz(3)
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  order                 Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([providerTransactionId])
  @@map("payments")
}

// ── Devices, push & notifications ─────────────────────────────────────────────
model Device {
  id                 String         @id @db.VarChar(64)
  userId             String         @map("user_id") @db.Uuid
  installId          String         @map("install_id") @db.VarChar(80)
  platform           DevicePlatform
  expoPushToken      String?        @map("expo_push_token")
  fcmToken           String?        @map("fcm_token")
  apnsToken          String?        @map("apns_token")
  osVersion          String?        @map("os_version") @db.VarChar(40)
  appVersion         String?        @map("app_version") @db.VarChar(40)
  deviceModel        String?        @map("device_model") @db.VarChar(80)
  locale             String?        @db.VarChar(20)
  timezone           String?        @db.VarChar(60)
  permissionsGranted Boolean        @default(false) @map("permissions_granted")
  lastSeenAt         DateTime       @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  user               AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens      RefreshToken[]

  @@unique([userId, installId])
  @@index([userId])
  @@map("devices")
}

model NotificationPreference {
  id              String   @id @db.VarChar(64)
  userId          String   @unique @map("user_id") @db.Uuid
  orders          Boolean  @default(true)
  payments        Boolean  @default(true)
  aiReplies       Boolean  @default(true) @map("ai_replies")
  masterMessages  Boolean  @default(true) @map("master_messages")
  marketing       Boolean  @default(false)
  quietHoursStart String?  @map("quiet_hours_start") @db.VarChar(5)
  quietHoursEnd   String?  @map("quiet_hours_end") @db.VarChar(5)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user            AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Notification {
  id           String           @id @db.VarChar(64)
  userId       String           @map("user_id") @db.Uuid
  type         NotificationType
  title        String           @db.VarChar(200)
  body         String
  data         Json?
  deeplinkPath String?          @map("deeplink_path")
  readAt       DateTime?        @map("read_at") @db.Timestamptz(3)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  user         AppUser          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
  @@map("notifications")
}

// ── AI advisor ────────────────────────────────────────────────────────────────
model AiSession {
  id         String      @id @db.VarChar(64)
  userId     String      @map("user_id") @db.Uuid
  vehicleId  String?     @map("vehicle_id") @db.VarChar(64)
  locale     String?     @db.VarChar(20)
  entryPoint String?     @map("entry_point") @db.VarChar(60)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)
  user       AppUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle    Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  messages   AiMessage[]

  @@index([userId])
  @@map("ai_sessions")
}

model AiMessage {
  id              String        @id @db.VarChar(64)
  sessionId       String        @map("session_id") @db.VarChar(64)
  role            AiMessageRole
  content         String
  clientMessageId String?       @map("client_message_id") @db.VarChar(64)
  attachments     Json?
  structured      Json?
  tokenCount      Int?          @map("token_count")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  session         AiSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("ai_messages")
}

// ── SMS accounting & operator pricing ─────────────────────────────────────────
// Additive analytics layer around the EXISTING SMS send path — no existing table,
// endpoint, provider, or the SmsProvider interface is touched. An SmsMessage row
// is written at send time with status='pending'; a future delivery callback (not
// yet implemented) flips status→delivered/failed and fills delivered_at, so no
// schema change is needed to add delivery tracking later.

model SmsOperator {
  id          Int                 @id @default(autoincrement())
  // Canonical, stable key (e.g. "beeline"); snapshotted onto SmsMessage.operatorName.
  name        String              @unique @db.VarChar(40)
  displayName String              @map("display_name") @db.VarChar(80)
  // Current price per SMS in UZS. NEVER used to recompute historical cost — each
  // SmsMessage snapshots the price in force at send time (see SmsMessage.priceUzs).
  priceUzs    Int                 @map("price_uzs")
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  prefixes    SmsOperatorPrefix[]
  messages    SmsMessage[]

  @@map("sms_operators")
}

model SmsOperatorPrefix {
  id         Int         @id @default(autoincrement())
  operatorId Int         @map("operator_id")
  // 2-digit MSISDN operator code after the 998 country code (e.g. "90"). Globally
  // unique: a prefix maps to exactly one operator.
  prefix     String      @unique @db.VarChar(8)
  operator   SmsOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@map("sms_operator_prefixes")
}

model SmsMessage {
  id                    Int          @id @default(autoincrement())
  // Transport that accepted the send (SmsProvider.name, e.g. "sayqal").
  provider              String       @db.VarChar(40)
  // Provider-returned identifiers/parts. Null at insert: the SmsProvider contract
  // returns void, so these are reserved for a later delivery callback.
  providerTransactionId String?      @map("provider_transaction_id") @db.VarChar(120)
  providerSmsId         String?      @map("provider_sms_id") @db.VarChar(120)
  phoneE164             String       @map("phone_e164") @db.VarChar(20)
  // Operator snapshot — resolved at send time and frozen. operatorName/priceUzs
  // are copies, never re-derived from SmsOperator, so historical cost is immutable
  // against later price edits. operatorId is a soft link (SET NULL on delete).
  operatorId            Int?         @map("operator_id")
  operatorName          String?      @map("operator_name") @db.VarChar(40)
  priceUzs              Int?         @map("price_uzs")
  // Optional message-template label (never the rendered text — OTP codes are not
  // persisted). Nullable for callers that don't tag their sends.
  template              String?      @db.VarChar(60)
  parts                 Int?
  // Lifecycle: 'pending' at insert → 'delivered' | 'failed' via future callback.
  status                String       @default("pending") @db.VarChar(20)
  errorCode             String?      @map("error_code") @db.VarChar(40)
  errorMessage          String?      @map("error_message") @db.Text
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  deliveredAt           DateTime?    @map("delivered_at") @db.Timestamptz(3)
  operator              SmsOperator? @relation(fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([operatorId])
  @@index([createdAt])
  @@index([phoneE164])
  @@map("sms_messages")
}
