# Mator Backend — environment variables
# Copy to .env and fill in real values. Never commit the populated .env file.

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (Prisma / PostgreSQL) ───────────────────────────────────────────
# Pooled connection used by the app at runtime (e.g. PgBouncer transaction mode).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&pgbouncer=true
# Direct (non-pooled) connection — required for `prisma migrate deploy`.
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# PEM keys. In production these are required — boot fails fast if any are missing.
# Newlines may be encoded as literal "\n" (the app normalizes them at startup).
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"
JWT_KID=replace-with-a-stable-key-id
JWT_AUDIENCE=mator-app

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated browser-origin allowlist. Empty = all browser origins rejected
# in production (the native mobile app sends no Origin and is unaffected).
CORS_ORIGINS=https://app.mator.uz,https://admin.mator.uz

# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=REPLACE_WITH_BOTFATHER_TOKEN

# ── Cloudinary (image storage) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=REPLACE_ME
CLOUDINARY_API_KEY=REPLACE_ME
CLOUDINARY_API_SECRET=REPLACE_ME

# ── Photoroom (AI background removal / beautify) ─────────────────────────────
PHOTOROOM_API_KEY=REPLACE_ME

# ── Image processing concurrency (1–10) ────────────────────────────────────────
IMAGE_CONCURRENCY=5

# ── Anthropic (Claude — AI advisor & part parsing) ───────────────────────────
ANTHROPIC_API_KEY=REPLACE_ME
# Set to "true" to bypass live AI calls and use the offline rule-based fallback.
AI_MOCK=false

# ── Email (Resend + verification links) ──────────────────────────────────────
RESEND_API_KEY=REPLACE_ME
MAIL_FROM="Mator <no-reply@mator.uz>"
EMAIL_VERIFY_URL=https://api.mator.uz/v1/auth/verify-email
EMAIL_VERIFY_SUCCESS_URL=https://mator.uz/verify/success
EMAIL_VERIFY_FAILURE_URL=https://mator.uz/verify/failure

# ── SMS (phone OTP) ───────────────────────────────────────────────────────────
# eskiz | log ("log" is the safe local/dev no-op default).
SMS_PROVIDER=log
ESKIZ_EMAIL=REPLACE_ME
ESKIZ_PASSWORD=REPLACE_ME
ESKIZ_FROM=REPLACE_ME
ESKIZ_BASE_URL=https://notify.eskiz.uz/api

# ── Push notifications ────────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=REPLACE_ME
# FCM (Android): paste the full service-account JSON as a single-line string.
FCM_SERVICE_ACCOUNT_JSON=
# APNs (iOS): paste the .p8 key contents. Providers no-op (log only) if unset.
APNS_KEY_P8=

# ── Social login ──────────────────────────────────────────────────────────────
# Comma-separated allowed client/audience IDs.
GOOGLE_CLIENT_IDS=REPLACE_ME
APPLE_CLIENT_IDS=REPLACE_ME

# ── MyID (identity verification) ─────────────────────────────────────────────
MYID_AUTHORIZE_URL=https://myid.uz/oauth2/authorize
MYID_CLIENT_ID=mator-dev
MYID_VERIFIED_LIMIT_UZS=

# ── Payments ───────────────────────────────────────────────────────────────────
# Comma-separated enabled providers, e.g. "payme,click".
PAYMENT_PROVIDERS=payme,click
PAYME_MERCHANT_KEY=REPLACE_ME
PAYME_ACCOUNT_FIELD=order_id
PAYME_CHECKOUT_URL=https://checkout.paycom.uz
CLICK_MERCHANT_ID=REPLACE_ME
CLICK_SERVICE_ID=REPLACE_ME
CLICK_SECRET_KEY=REPLACE_ME

# ── Orders / shipping / retention (business config, all optional — sane defaults) ──
ORDER_TTL_MIN=30
SERVICE_FEE_UZS=5000
DELIVERY_COURIER_UZS=25000
RETENTION_DAYS=90

AUTH_DEV_MODE=false